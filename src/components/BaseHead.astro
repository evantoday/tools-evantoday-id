---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalURL?: string;
	ogImage?: string;
}

const SITE_NAME = 'EvanTools';
const {
	title,
	description,
	canonicalURL: customCanonical,
	ogImage,
} = Astro.props;

const canonicalURL = customCanonical
	? new URL(customCanonical, Astro.site)
	: new URL(Astro.url.pathname, Astro.site);

const fullTitle = title === SITE_NAME
	? title
	: title.length + SITE_NAME.length + 3 > 60
		? title
		: `${title} | ${SITE_NAME}`;

const socialImage = ogImage
	? new URL(ogImage, Astro.site).toString()
	: new URL('/og-default.png', Astro.site).toString();

const gaId = import.meta.env.PUBLIC_GA_ID;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Robots -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImage} />

<!-- Google Analytics -->
{gaId && (
	<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
	<script define:vars={{ gaId }}>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());
		gtag('config', gaId);
	</script>
)}

<!-- AdSense -->
{adsenseClient && (
	<script
		async
		src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
		crossorigin="anonymous"
	/>
)}
