---
const year = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-100 mt-16">
	<div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
		<div class="flex flex-col sm:flex-row items-center justify-between gap-4">
			<div class="flex items-center gap-4 text-sm text-gray-500">
				<a href="/privacy-policy" class="hover:text-gray-700 transition-colors">Privacy Policy</a>
				<span class="text-gray-300">|</span>
				<a href="/terms" class="hover:text-gray-700 transition-colors">Terms of Service</a>
			</div>
			<div class="text-sm text-gray-500">
				A project by <a href="https://evantoday.id" class="text-gray-700 hover:text-gray-900 font-medium transition-colors">Evan Today</a>
			</div>
		</div>
		<div class="mt-6 text-center text-xs text-gray-400">
			&copy; {year} EvanTools. All rights reserved.
		</div>
	</div>
</footer>
