---
import type { Tool } from '../data/tools';

interface Props {
	tool: Tool;
}

const { tool } = Astro.props;
---

<div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
	<!-- Form -->
	<form id="download-form" class="relative">
		<div
			class="flex flex-col sm:flex-row gap-3 p-2 rounded-2xl border-2 border-gray-200 bg-white shadow-sm focus-within:border-current focus-within:shadow-md transition-all duration-200"
			style={`color: ${tool.color}`}
		>
			<input
				id="url-input"
				type="url"
				name="url"
				required
				autocomplete="off"
				placeholder={tool.placeholder}
				class="flex-1 px-4 py-3 text-gray-900 placeholder-gray-400 bg-transparent outline-none text-sm sm:text-base rounded-xl"
			/>
			<button
				id="download-btn"
				type="submit"
				class="px-8 py-3 text-white font-semibold rounded-xl text-sm sm:text-base transition-all duration-200 hover:opacity-90 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2 min-w-[140px]"
				style={`background-color: ${tool.color}`}
			>
				<span id="btn-text">Download</span>
				<svg id="btn-spinner" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
					<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
					<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
				</svg>
			</button>
		</div>
	</form>

	<!-- Result Area -->
	<div id="result-area" class="mt-6 hidden">
		<!-- Success State -->
		<div id="result-success" class="hidden">
			<div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
				<!-- Preview Header -->
				<div class="flex items-center gap-4 p-4 sm:p-5 border-b border-gray-100">
					<div id="media-preview" class="w-16 h-16 sm:w-20 sm:h-20 rounded-xl bg-gray-100 overflow-hidden flex-shrink-0 flex items-center justify-center">
						<svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
						</svg>
					</div>
					<div class="min-w-0 flex-1">
						<p id="media-title" class="font-semibold text-gray-900 text-sm sm:text-base truncate">Media found</p>
						<p id="media-source" class="text-xs sm:text-sm text-gray-500 mt-0.5">{tool.shortName}</p>
					</div>
				</div>
				<!-- Download Links -->
				<div id="download-links" class="p-4 sm:p-5 space-y-2">
					<!-- Dynamically populated -->
				</div>
			</div>
		</div>

		<!-- Error State -->
		<div id="result-error" class="hidden">
			<div class="bg-red-50 border border-red-200 rounded-2xl p-5 text-center">
				<svg class="w-10 h-10 text-red-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
				</svg>
				<p id="error-message" class="text-red-700 font-medium text-sm sm:text-base">Something went wrong</p>
				<p class="text-red-500 text-xs sm:text-sm mt-1">Please check the URL and try again.</p>
				<button
					id="retry-btn"
					class="mt-4 px-6 py-2 bg-red-100 text-red-700 font-medium rounded-xl text-sm hover:bg-red-200 transition-colors"
				>
					Try Again
				</button>
			</div>
		</div>
	</div>
</div>

<script>
	const form = document.getElementById('download-form') as HTMLFormElement;
	const urlInput = document.getElementById('url-input') as HTMLInputElement;
	const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;
	const btnText = document.getElementById('btn-text') as HTMLElement;
	const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
	const resultArea = document.getElementById('result-area') as HTMLElement;
	const resultSuccess = document.getElementById('result-success') as HTMLElement;
	const resultError = document.getElementById('result-error') as HTMLElement;
	const errorMessage = document.getElementById('error-message') as HTMLElement;
	const downloadLinks = document.getElementById('download-links') as HTMLElement;
	const mediaPreview = document.getElementById('media-preview') as HTMLElement;
	const mediaTitle = document.getElementById('media-title') as HTMLElement;
	const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;

	function setLoading(loading: boolean) {
		downloadBtn.disabled = loading;
		btnText.textContent = loading ? 'Processing...' : 'Download';
		btnSpinner.classList.toggle('hidden', !loading);
	}

	function showSuccess(data: any) {
		resultArea.classList.remove('hidden');
		resultSuccess.classList.remove('hidden');
		resultError.classList.add('hidden');

		if (data.title) {
			mediaTitle.textContent = data.title;
		}

		// Show thumbnail if available
		if (data.thumbnail) {
			mediaPreview.innerHTML = `<img src="${data.thumbnail}" alt="Preview" class="w-full h-full object-cover" />`;
		}

		// Render download links
		downloadLinks.innerHTML = '';
		if (data.media && data.media.length > 0) {
			data.media.forEach((dl: any) => {
				const link = document.createElement('a');
				link.href = dl.url;
				link.download = '';
				link.target = '_blank';
				link.rel = 'noopener noreferrer';
				link.className =
					'flex items-center justify-between px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-xl transition-colors group';
				link.innerHTML = `
					<div class="flex items-center gap-3">
						<svg class="w-5 h-5 text-gray-500 group-hover:text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
						</svg>
						<span class="text-sm font-medium text-gray-700 group-hover:text-gray-900">${dl.filename || 'Download'}</span>
					</div>
					<span class="text-xs text-gray-400 uppercase">${dl.type || ''}</span>
				`;
				downloadLinks.appendChild(link);
			});
		}
	}

	function showError(message: string) {
		resultArea.classList.remove('hidden');
		resultSuccess.classList.add('hidden');
		resultError.classList.remove('hidden');
		errorMessage.textContent = message;
	}

	function resetResult() {
		resultArea.classList.add('hidden');
		resultSuccess.classList.add('hidden');
		resultError.classList.add('hidden');
		downloadLinks.innerHTML = '';
	}

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		const url = urlInput.value.trim();
		if (!url) return;

		resetResult();
		setLoading(true);

		try {
			const res = await fetch('/api/download', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ url }),
			});

			if (res.status === 429) {
				showError('Too many requests. Please wait a moment and try again.');
				return;
			}

			const data = await res.json();

			if (!data.success) {
				showError(data.error || 'Failed to process this URL. Please check and try again.');
				return;
			}

			showSuccess(data);
		} catch {
			showError('Network error. Please check your connection and try again.');
		} finally {
			setLoading(false);
		}
	});

	retryBtn.addEventListener('click', () => {
		resetResult();
		urlInput.focus();
	});
</script>
