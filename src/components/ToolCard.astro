---
import type { Tool } from '../data/tools';

interface Props {
	tool: Tool;
}

const { tool } = Astro.props;

// Extract first sentence of description
const shortDesc = tool.description.split('. ')[0] + '.';

const hasVideo = tool.supportedTypes.includes('video');
const hasImage = tool.supportedTypes.includes('image');
const hasAudio = tool.supportedTypes.includes('audio');
---

<a
	href={`/${tool.slug}`}
	class="group block bg-white border border-gray-200 rounded-2xl p-5 sm:p-6 hover:shadow-lg hover:border-transparent transition-all duration-200 no-underline"
	style={`--accent: ${tool.color}`}
>
	<div class="flex items-start justify-between mb-3">
		<h3 class="font-bold text-gray-900 text-base sm:text-lg group-hover:text-[var(--accent)] transition-colors">
			{tool.shortName}
		</h3>
		<div class="flex items-center gap-1.5 ml-3 flex-shrink-0">
			{hasVideo && (
				<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-100 text-[10px] font-medium text-gray-600 uppercase tracking-wide">
					<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
					</svg>
					Video
				</span>
			)}
			{hasImage && (
				<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-100 text-[10px] font-medium text-gray-600 uppercase tracking-wide">
					<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91" />
					</svg>
					Image
				</span>
			)}
			{hasAudio && (
				<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-gray-100 text-[10px] font-medium text-gray-600 uppercase tracking-wide">
					<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424" />
					</svg>
					Audio
				</span>
			)}
		</div>
	</div>
	<p class="text-sm text-gray-500 leading-relaxed">{shortDesc}</p>
	<div class="mt-4 flex items-center gap-1 text-sm font-medium text-[var(--accent)] opacity-0 group-hover:opacity-100 transition-opacity duration-200">
		<span>Open tool</span>
		<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
		</svg>
	</div>
</a>
